generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model CampRecord {
  id        Int      @id @default(autoincrement())
  name      String
  date      DateTime
  memo      String?
  photos    String   @default("[]")
  lat       Float
  lng       Float
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
